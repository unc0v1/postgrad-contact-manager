{
  "name": "postgrad-contact-manager",
  "version": "0.1.0",
  "private": true,
  "description": "研究生复试套磁管理系统 - 帮助保研生和考研生管理导师联系全过程",
  "scripts": {
    "dev": "concurrently \"pnpm --filter client dev\" \"pnpm --filter server dev\"",
    "dev:client": "pnpm --filter client dev",
    "dev:server": "pnpm --filter server dev",
    "build": "pnpm --filter shared build && pnpm --filter client build && pnpm --filter server build",
    "db:migrate": "prisma migrate dev",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "lint": "eslint . --ext .ts,.vue",
    "setup": "pnpm install && pnpm db:migrate && pnpm db:seed"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "prisma": "^6.4.0",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "@prisma/client": "^6.4.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "prisma",
      "vue-demi"
    ]
  }
}
